<?xml version="1.0" encoding="utf-8"?>
<!--
  City3D demo — package sources.

  The whole point of this demo is to consume the SumoSharp.* packages AS PACKAGES, from a LOCAL feed,
  never from nuget.org (they are not published there yet). `packageSourceMapping` pins every `SumoSharp.*`
  id to the local feed, so our packages can NEVER be silently resolved from nuget.org — that pin is the
  thing being proved. Everything else (the Godot SDK, the BCL, CycloneDDS for the remote path) resolves
  from nuget.org as usual.

  Populate ./local-nuget by running ./build.sh (which `dotnet pack`s the needed SumoSharp packages).
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="sumosharp-local" value="./local-nuget" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="sumosharp-local">
      <package pattern="SumoSharp.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
