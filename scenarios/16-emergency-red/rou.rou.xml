<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    <!-- A3 (emergency privilege: ignore red). An emergency vehicle (vClass=emergency, sigma=0)
         drives WJ JE through the traffic-light junction J while the signal is RED (0..29 s). With
         the junction-model attribute jmDriveAfterRedTime="1000" it IGNORES the red
         (MSVehicle::ignoreRed is true while redDuration is below jmDriveAfterRedTime) and drives
         straight through at free-flow, whereas the rung-10 passenger halts. Contrast to scenario 09. -->
    <vType id="emg" vClass="emergency" sigma="0" jmDriveAfterRedTime="1000"/>
    <route id="r0" edges="WJ JE"/>
    <vehicle id="veh0" type="emg" route="r0" depart="0" departPos="0" departSpeed="0" departLane="0"/>
</routes>
