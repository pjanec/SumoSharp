<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    <!-- Single-track bidirectional MEET (rung R3). AB and BA share one physical track
         (netconvert marks each the other's bidi=). Two rail trains depart at t=0 from
         opposite ends. With no rail signal, SUMO's deadlock guard holds the SECOND train
         at INSERTION until the first has cleared the shared track: tBA cannot enter BA
         while its bidi partner AB carries tAB. tBA therefore inserts only once tAB exits
         (~t=89), then runs A-ward. Rail sigma default 0 => deterministic. -->
    <vType id="train" vClass="rail" carFollowModel="Krauss"/>
    <route id="rAB" edges="AB"/>
    <route id="rBA" edges="BA"/>
    <vehicle id="trainAB" type="train" route="rAB" depart="0" departPos="0" departSpeed="0" departLane="0"/>
    <vehicle id="trainBA" type="train" route="rBA" depart="0" departPos="0" departSpeed="0" departLane="0"/>
</routes>
