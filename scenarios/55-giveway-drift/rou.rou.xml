<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    <!-- ER5 behavioral-test fixture: a SINGLE wide lane (e0_0, width 6 m, 600 m long). A slow
         regular car (car0, maxSpeed 6) drives ahead; a blue-light EMERGENCY vehicle (ev,
         hasBluelight) catches up behind it in the same (only) lane. With no lane to change into,
         car0 gives way by PULLING TO THE LANE EDGE (a lateral drift reusing the B6 primitive), and
         the EV passes it within the lane (their lateral footprints no longer overlap on the wide
         lane). car0 recenters after the EV clears. This is the case SUMO's lane-based rescue cannot
         form at all; there is NO SUMO golden. Behavioral property tests: car0 drifts off-centre
         while the EV is near, the EV gets past car0, the two never physically overlap, and car0
         returns to the lane centre afterwards. -->
    <vType id="car" vClass="passenger" sigma="0" maxSpeed="6"/>
    <vType id="emg" vClass="emergency" sigma="0" maxSpeed="13.89" hasBluelight="true"/>
    <route id="r0" edges="e0"/>
    <vehicle id="car0" type="car" route="r0" depart="0" departPos="60" departSpeed="0" departLane="0"/>
    <vehicle id="ev"   type="emg" route="r0" depart="0" departPos="0"  departSpeed="0" departLane="0"/>
</routes>
