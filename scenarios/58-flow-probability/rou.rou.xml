<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    <!-- T1 fixture: probabilistic <flow probability=> for ENSEMBLE statistical parity vs SUMO. A
         single probability flow on a 500 m single lane: each second, insert a passenger car with
         probability 0.15 over [0, 60). Whether a given Bernoulli hit actually inserts is gated by the
         entry-lane occupancy (a just-inserted car at pos 0 / speed 0 blocks the next insertion until
         it clears), so the realized insertion COUNT is well below the raw hit rate (mean ~8.7, not
         0.15*60=9-ish only because gating and the Bernoulli variance roughly cancel here). Our per-
         flow seeded RNG is deliberately NOT SUMO's flow RNG, so individual insertion times do not
         match a specific SUMO run; the parity bar is the ensemble insertion-count DISTRIBUTION
         (RungT1ProbabilisticFlowEnsembleTests), the same statistical bar as C1/C7. -->
    <vType id="car" vClass="passenger" sigma="0"/>
    <route id="r0" edges="e0"/>
    <flow id="p" type="car" route="r0" begin="0" end="60" probability="0.15"
          departPos="0" departSpeed="0" departLane="0"/>
</routes>
