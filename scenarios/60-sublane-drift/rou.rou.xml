<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    <!-- sigma=0 (deterministic). latAlignment="right": the sublane model steers the vehicle
         from its centred insertion toward the right lane edge at maxSpeedLat (default 1.0 m/s). -->
