<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    <!-- heterogeneous flow on a 7.2 m wide lane (sublane): interleaved fast and slow vehicles, so the
         fast ones must overtake the slow ones laterally. Deterministic (sigma=0). Used for an
         AGGREGATE statistical cross-check of the laneless RVO model vs SUMO's sublane run. -->
    <vType id="fast" vClass="passenger" sigma="0"/>
    <vType id="slow" vClass="passenger" sigma="0" maxSpeed="6"/>
    <route id="r0" edges="e0"/>
    <vehicle id="f0" type="fast" route="r0" depart="0"  departPos="0" departSpeed="0"/>
    <vehicle id="s0" type="slow" route="r0" depart="1"  departPos="0" departSpeed="0"/>
    <vehicle id="f1" type="fast" route="r0" depart="2"  departPos="0" departSpeed="0"/>
    <vehicle id="s1" type="slow" route="r0" depart="3"  departPos="0" departSpeed="0"/>
    <vehicle id="f2" type="fast" route="r0" depart="4"  departPos="0" departSpeed="0"/>
    <vehicle id="s2" type="slow" route="r0" depart="5"  departPos="0" departSpeed="0"/>
    <vehicle id="f3" type="fast" route="r0" depart="6"  departPos="0" departSpeed="0"/>
    <vehicle id="s3" type="slow" route="r0" depart="7"  departPos="0" departSpeed="0"/>
</routes>
