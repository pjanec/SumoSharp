<?xml version="1.0" encoding="UTF-8"?>

<!-- Hand-written (modeled on scenarios/48-parking-depart/net.net.xml and
     scenarios/07-keep-right-change/net.net.xml's 2-lane shape), matching what netconvert would
     emit for a single straight 2-lane dead-end edge: two <node>s joined by one <edge>, no
     junctions, no turnarounds. -->
<net version="1.20" limitTurnSpeed="5.50" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/net_file.xsd">

    <location netOffset="0.00,0.00" convBoundary="0.00,0.00,120.00,0.00" origBoundary="0.00,0.00,120.00,0.00" projParameter="!"/>

    <edge id="e0" from="n0" to="n1" priority="-1">
        <lane id="e0_0" index="0" speed="13.89" length="120.00" shape="0.00,-4.80 120.00,-4.80"/>
        <lane id="e0_1" index="1" speed="13.89" length="120.00" shape="0.00,-1.60 120.00,-1.60"/>
    </edge>

    <junction id="n0" type="dead_end" x="0.00" y="0.00" incLanes="" intLanes="" shape="0.00,0.00 0.00,-6.40"/>
    <junction id="n1" type="dead_end" x="120.00" y="0.00" incLanes="e0_0 e0_1" intLanes="" shape="120.00,-6.40 120.00,0.00"/>

</net>
