<routes>
    <!-- sigma=0 for exact phase-1 determinism (CLAUDE.md). Both cars depart t=0, drive the 120 m
         approach (about 9 s at 13.89 m/s) and reach junction C together. -->
    <vType id="car" accel="2.6" decel="4.5" sigma="0" length="5.0" maxSpeed="13.89"/>

    <!-- Car A: N to E left turn is link 2, RED for the whole run (TL phase is E/W green). It waits
         at the stop line, present so the RBL cycle detector collects link 2 alongside link 5. -->
    <vehicle id="n_left" type="car" depart="0" departSpeed="max">
        <route edges="NtoC CtoE"/>
    </vehicle>

    <!-- Car B: E to S left turn is link 5, GREEN (permissive). No oncoming W through is present, so
         it proceeds freely in vanilla. The TL blind RBL, however, finds the {2,5} mutual response
         cycle and (greedy ascending index) selects the RED link 2 as pass while HOLDING the green
         link 5, freezing this car. That freeze is the P2-G Bug-2 divergence. -->
    <vehicle id="e_left" type="car" depart="0" departSpeed="max">
        <route edges="EtoC CtoS"/>
    </vehicle>
</routes>
